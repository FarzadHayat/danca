---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Danca | Page Not Found">
	<main class="min-h-screen flex items-center justify-center p-6 text-center">
		<div>
			<h1 class="text-9xl font-bold text-white/10 mb-[-1.5rem]">404</h1>
			<h2 class="text-4xl font-bold mb-6">Lost in the rhythm?</h2>
			<p class="text-slate-400 mb-8 max-w-md mx-auto">
				We couldn't find the page you're looking for. It might have moved or doesn't exist yet.
			</p>
			<a 
				href="/" 
				class="inline-block bg-white text-slate-950 font-bold px-8 py-3 rounded-xl hover:bg-purple-500 hover:text-white transition-all active:scale-95"
			>
				Back to Main
			</a>
		</div>
	</main>
</Layout>
