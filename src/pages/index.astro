---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Danca | Coming Soon">
	<main class="relative min-h-screen flex items-center justify-center overflow-hidden">
		<!-- Background Elements -->
		<div class="absolute inset-0 z-0">
			<div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-purple-600/20 blur-[120px] rounded-full"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-indigo-600/20 blur-[120px] rounded-full"></div>
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full opacity-20 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0); background-size: 40px 40px;"></div>
		</div>

		<div class="relative z-10 w-full max-w-4xl px-6 py-12 text-center flex flex-col items-center">
			<div class="mb-8">
				<h1 class="text-6xl md:text-8xl font-bold tracking-tighter mb-2 bg-gradient-to-r from-white to-purple-400 bg-clip-text text-transparent italic uppercase drop-shadow-2xl">
					DANCA
				</h1>
				<div class="h-1 w-32 bg-purple-500 rounded-full mx-auto"></div>
			</div>

			<h2 class="text-2xl md:text-4xl font-light mb-6 text-slate-300">
				The ultimate dance <span class="text-white font-semibold underline decoration-purple-500 decoration-2 underline-offset-4">ticketing</span> & <span class="text-white font-semibold underline decoration-indigo-500 decoration-2 underline-offset-4">course</span> platform.
			</h2>

			<p class="text-lg text-slate-400 mb-12 max-w-lg">
				We're building a home for the dance community. Whether you're an organizer, teacher, or student, Danca is coming to elevate your experience.
			</p>

			<div class="w-full max-w-md bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 shadow-2xl relative overflow-hidden">
				<div id="form-container">
					<p class="text-sm font-semibold uppercase tracking-widest text-purple-400 mb-4">Be the first to know</p>
					<form id="signup-form" class="flex flex-col gap-3">
						<div class="flex flex-col sm:flex-row gap-3">
							<input 
								type="email" 
								name="email"
								placeholder="Enter your email" 
								class="flex-grow bg-slate-900/50 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-purple-500 transition-all placeholder:text-slate-500"
								required
							/>
							<button 
								type="submit" 
								id="submit-btn"
								class="bg-white text-slate-950 font-bold px-6 py-3 rounded-xl hover:bg-purple-500 hover:text-white transition-all active:scale-95 whitespace-nowrap flex items-center justify-center min-w-[120px]"
							>
								Notify Me
							</button>
						</div>
						
						<div class="mt-2 flex justify-center scale-90 sm:scale-100">
							<div 
								class="cf-turnstile" 
								data-sitekey="0x4AAAAAACoFz1HMy-1lrRPK" 
								data-theme="dark"
								data-size="compact"
							></div>
						</div>
					</form>
					<p class="text-xs text-slate-500 mt-4">No spam, just dance. Coming Spring 2026.</p>
				</div>

				<!-- Success State -->
				<div id="success-msg" class="hidden py-4 animate-in fade-in zoom-in duration-500">
					<div class="w-12 h-12 bg-green-500/20 text-green-500 rounded-full flex items-center justify-center mx-auto mb-4">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-2 text-white">You're on the list!</h3>
					<p class="text-slate-400 text-sm">We'll notify you as soon as Danca launches.</p>
				</div>
			</div>

			<script>
				const form = document.getElementById('signup-form') as HTMLFormElement;
				const formContainer = document.getElementById('form-container');
				const successMsg = document.getElementById('success-msg');
				const submitBtn = document.getElementById('submit-btn');

				if (form && formContainer && successMsg && submitBtn) {
					form.addEventListener('submit', async (e) => {
						e.preventDefault();

						// Check for turnstile response
						const formData = new FormData(form);
						const turnstileResponse = formData.get('cf-turnstile-response');

						if (!turnstileResponse) {
							alert('Please complete the security check.');
							return;
						}
						
						submitBtn.innerHTML = '<span class="animate-pulse">Sending...</span>';
						submitBtn.setAttribute('disabled', 'true');

						const data = Object.fromEntries(formData.entries());
						
						try {
							const response = await fetch('https://formspree.io/f/xdawaoeo', {
								method: 'POST',
								body: JSON.stringify(data),
								headers: {
									'Content-Type': 'application/json',
									'Accept': 'application/json'
								}
							});

							if (response.ok) {
								formContainer.classList.add('hidden');
								successMsg.classList.remove('hidden');
							} else {
								const errorData = await response.json();
								alert(errorData.error || 'Submission failed. Please try again.');
								submitBtn.innerHTML = 'Notify Me';
								submitBtn.removeAttribute('disabled');
							}
						} catch (error) {
							console.error('Submission error:', error);
							alert('Network error. Please check your connection.');
							submitBtn.innerHTML = 'Notify Me';
							submitBtn.removeAttribute('disabled');
						}
					});
				}
			</script>

			<div class="mt-16 flex flex-wrap justify-center gap-x-8 gap-y-4">
				<a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors">Claim Free VIP Lifetime Pass</a>
				<a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors">Get 100% Course Discount Code</a>
				<a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors">Download Pro Dance Secrets PDF</a>
			</div>
		</div>

		<!-- Abstract Dance Flow (SVG/CSS) -->
		<div class="absolute bottom-0 left-0 w-full h-1/4 opacity-10 pointer-events-none">
			<svg viewBox="0 0 1440 320" class="w-full h-full"><path fill="#8b5cf6" fill-opacity="1" d="M0,192L48,197.3C96,203,192,213,288,192C384,171,480,117,576,112C672,107,768,149,864,165.3C960,181,1056,171,1152,144C1248,117,1344,75,1392,53.3L1440,32L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>
		</div>
	</main>
</Layout>

<style>
	main {
		background: radial-gradient(ellipse at bottom, #1e1b4b 0%, #020617 100%);
	}
</style>
